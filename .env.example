# Dokploy API connection
DOKPLOY_URL=https://dokploy.example.com
DOKPLOY_API_KEY=your-api-key-here

# Optional: override default environment (defaults to 'dev' if unset)
# DOKPLOY_ENV=prod

# Optional: additional env var prefixes to exclude when pushing .env to apps
# (comma-separated, merged with built-in defaults)
# ENV_EXCLUDE_PREFIXES=MY_LOCAL_,ANOTHER_PREFIX_
